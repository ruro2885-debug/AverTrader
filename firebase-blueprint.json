{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Bonus": {
      "title": "Bonus",
      "description": "Bonus definitions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "rewardAmount": { "type": "number" },
        "rewardCurrency": { "type": "string" },
        "type": { "type": "string" },
        "unlockRequirements": { "type": "object" }
      },
      "required": ["id", "title", "rewardAmount", "type"]
    },
    "UserBonus": {
      "title": "UserBonus",
      "description": "Bonus instance for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bonusId": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "locked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "bonusId", "status", "locked", "createdAt"]
    },
    "BonusHistory": {
      "title": "BonusHistory",
      "description": "Bonus event audit trail",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bonusId": { "type": "string" },
        "event": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "bonusId", "event", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "actionUrl": { "type": "string" },
        "pinned": { "type": "boolean" },
        "archived": { "type": "boolean" }
      },
      "required": ["id", "userId", "category", "priority", "title", "body", "createdAt", "read"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/bonuses/{bonusId}": { "schema": "Bonus", "description": "Bonus templates" },
    "/userBonuses/{uid}/{bonusId}": { "schema": "UserBonus", "description": "User bonus status" },
    "/bonusHistory/{eventId}": { "schema": "BonusHistory", "description": "Bonus audit log" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" }
  }
}
