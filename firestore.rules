rules_version = '2';
service cloudfire.firestore {
  match /databases/{database}/documents {

    // 1. Catch-all Default Deny Gate
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Reusable Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Entity-Specific Validation Blueprints (Anti-Update-Gaps)
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.uid is string
        && data.uid.size() <= 128
        && data.email is string
        && data.email.size() <= 256
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 204800))
        && (!('onboardingCompleted' in data) || data.onboardingCompleted is bool)
        && (!('subscriptionPlan' in data) || data.subscriptionPlan in ['Free', 'Pro', 'Enterprise'])
        && (!('aiTradingStatus' in data) || data.aiTradingStatus in ['active', 'paused', 'stopped'])
        && (!('kycStatus' in data) || data.kycStatus in ['unverified', 'pending', 'verified', 'rejected'])
        && (!('kycDocumentURL' in data) || (data.kycDocumentURL is string && data.kycDocumentURL.size() <= 1000000))
        && (!('referralCode' in data) || (data.referralCode is string && data.referralCode.size() <= 50))
        && (!('referredBy' in data) || (data.referredBy is string && data.referredBy.size() <= 50))
        && (!('referralRewards' in data) || (data.referralRewards is number && data.referralRewards >= 0));
    }

    function isValidPortfolio(data) {
      return data.keys().hasAll(['userId', 'balance'])
        && data.userId is string
        && data.balance is number
        && data.balance >= 0
        && (!('totalDeposits' in data) || (data.totalDeposits is number && data.totalDeposits >= 0))
        && (!('totalWithdrawals' in data) || (data.totalWithdrawals is number && data.totalWithdrawals >= 0))
        && (!('todayPnL' in data) || data.todayPnL is number)
        && (!('todayPnLPercent' in data) || data.todayPnLPercent is number)
        && (!('overallReturn' in data) || data.overallReturn is number);
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'amount', 'status', 'createdAt'])
        && data.id is string
        && data.userId is string
        && data.type in ['deposit', 'withdrawal', 'trade']
        && data.amount is number
        && data.amount > 0
        && data.status in ['pending', 'completed', 'failed']
        && (!('txHash' in data) || (data.txHash is string && data.txHash.size() <= 256))
        && (!('asset' in data) || (data.asset is string && data.asset.size() <= 20));
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'title', 'message', 'read', 'createdAt'])
        && data.id is string
        && data.userId is string
        && data.type in ['trade', 'deposit', 'withdrawal', 'profit', 'maintenance', 'security']
        && data.title is string
        && data.title.size() <= 256
        && data.message is string
        && data.message.size() <= 2048
        && data.read is bool;
    }

    // 4. Secured Path Mappings
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && (!('createdAt' in existing()) || incoming().createdAt == existing().createdAt)
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'displayName', 'photoURL', 'onboardingCompleted', 'subscriptionPlan', 
          'aiTradingStatus', 'kycStatus', 'kycDocumentURL', 'referralCode', 
          'referredBy', 'referralRewards', 'settings', 'updatedAt'
        ]);
      allow delete: if false;

      // Nested Subcollection: Portfolio
      match /portfolio/main {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPortfolio(incoming());
        allow update: if isOwner(userId) && isValidPortfolio(incoming());
        allow delete: if false;
      }

      // Nested Subcollection: Transactions
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) 
          && isValidId(transactionId) 
          && isValidTransaction(incoming()) 
          && incoming().createdAt == request.time;
        // User cannot arbitrarily update historical transactions once processed, only system can or user can change pending status under strict gates
        allow update: if isOwner(userId) 
          && isValidId(transactionId) 
          && isValidTransaction(incoming())
          && incoming().id == existing().id
          && incoming().type == existing().type
          && incoming().amount == existing().amount
          && (existing().status == 'pending' && incoming().status in ['pending', 'completed', 'failed']);
        allow delete: if false;
      }

      // Nested Subcollection: Notifications
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) 
          && isValidId(notificationId) 
          && isValidNotification(incoming()) 
          && incoming().createdAt == request.time;
        allow update: if isOwner(userId) 
          && isValidId(notificationId) 
          && isValidNotification(incoming())
          && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
