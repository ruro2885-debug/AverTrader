rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate & Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Reusable Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. User Profiles & Subcollections
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Recursive wildcard for all subcollections (holdings, trades, snapshots, etc.)
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // 4. User Bonus States
    match /userBonuses/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // 5. Referrals (Relational logic)
    match /referrals/{referralId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource == null || resource.data.referrerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.referrerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.referrerId == request.auth.uid;
    }

    // 6. Static Data (Read-only for signed-in users)
    match /bonuses/{bonusId} {
      allow read, list: if isSignedIn();
    }

    // 7. Notifications
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 8. Global Public Data (Leaderboard)
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
