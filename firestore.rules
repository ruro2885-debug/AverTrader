rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate & Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Reusable Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. User Profiles & Subcollections
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /holdings/{holdingId} {
        allow read, write: if isOwner(userId);
      }
      match /trades/{tradeId} {
        allow read, write: if isOwner(userId);
      }
      match /snapshots/{snapshotId} {
        allow read, write: if isOwner(userId);
      }
      match /aiPreferences/{prefId} {
        allow read, write: if isOwner(userId);
      }
      match /tradingConfig/{configId} {
        allow read, write: if isOwner(userId);
      }
      match /positions/{positionId} {
        allow read, write: if isOwner(userId);
      }
      match /activity/{activityId} {
        allow read, write: if isOwner(userId);
      }
      match /aiConfigurations/{configId} {
        allow read, write: if isOwner(userId);
      }
      match /portfolio/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }

      // Recursive wildcard for all subcollections (holdings, trades, snapshots, etc.)
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // 4. User Bonus States
    match /wallets/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /userBonuses/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // 5. Referrals (Relational logic)
    match /referrals/{referralId} {
      allow get, list: if isSignedIn() && resource.data.referrerId == request.auth.uid;
      allow create, update, delete: if isSignedIn() && request.resource.data.referrerId == request.auth.uid;
    }

    // 6. Static Data (Read-only for signed-in users)
    match /bonuses/{bonusId} {
      allow read, list: if isSignedIn();
    }

    // 7. Notifications
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 8. Global Public Data (Leaderboard)
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // 9. AI Trading
    match /aiPreferences/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /aiSessions/{sessionId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    match /aiRecommendations/{recId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    // 10. Global Events Hub
    match /events_hub/{eventId} {
      allow read, list: if true;
      allow write, create, update, delete: if true;
    }
  }
}
